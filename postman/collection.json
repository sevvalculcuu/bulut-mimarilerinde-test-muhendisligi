{
	"info": {
		"_postman_id": "b3e5c942-881c-4b5c-a5b8-5a4325e83a45",
		"name": "Q-Flow API Collection",
		"description": "Postman API automated assertions test suite for QR Code Generator Service (Topic 35). Runs in CI using Newman.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Health Check",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"pm.test(\"Health status is healthy\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.status).to.eql(\"healthy\");",
							"    pm.expect(jsonData.service).to.eql(\"qrcode-generator-service\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/healthz",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"healthz"
					]
				}
			},
			"response": []
		},
		{
			"name": "Create QR Code",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 201\", function () {",
							"    pm.response.to.have.status(201);",
							"});",
							"pm.test(\"Verify QR attributes are present\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property(\"id\");",
							"    pm.expect(jsonData.title).to.eql(\"Postman Automated QR\");",
							"    pm.expect(jsonData.target_url).to.include(\"insider.com\");",
							"    pm.expect(jsonData).to.have.property(\"s3_url\");",
							"    ",
							"    // Save generated ID to postman environment variable for downstream tests",
							"    pm.environment.set(\"qr_id\", jsonData.id);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"title\": \"Postman Automated QR\",\n    \"target_url\": \"https://useinsider.com\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/v1/qrcodes",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"v1",
						"qrcodes"
					]
				}
			},
			"response": []
		},
		{
			"name": "List QR Codes",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"pm.test(\"Response is an array containing QR Codes\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.be.an(\"array\");",
							"    pm.expect(jsonData.length).to.be.at.least(1);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/v1/qrcodes",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"v1",
						"qrcodes"
					]
				}
			},
			"response": []
		},
		{
			"name": "Get QR Code Details",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"pm.test(\"Verify fields of created QR code\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.id).to.eql(parseInt(pm.environment.get(\"qr_id\")));",
							"    pm.expect(jsonData.title).to.eql(\"Postman Automated QR\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/v1/qrcodes/{{qr_id}}",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"v1",
						"qrcodes",
						"{{qr_id}}"
					]
				}
			},
			"response": []
		},
		{
			"name": "Verify Redirect and Scan Log",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is successful 2xx or 3xx redirection\", function () {",
							"    // Newman will automatically follow redirect by default, giving 200 OK from insider.com",
							"    // or a 302 if redirect is not followed. Both cases are correct integrations.",
							"    pm.expect(pm.response.code).to.be.oneOf([200, 301, 302]);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/qr/{{qr_id}}",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"qr",
						"{{qr_id}}"
					]
				}
			},
			"response": []
		},
		{
			"name": "Delete QR Code",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 204 No Content\", function () {",
							"    pm.response.to.have.status(204);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "DELETE",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/v1/qrcodes/{{qr_id}}",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"v1",
						"qrcodes",
						"{{qr_id}}"
					]
				}
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://127.0.0.1:8000",
			"type": "string"
		}
	]
}
